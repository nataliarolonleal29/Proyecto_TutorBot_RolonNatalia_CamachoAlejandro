    {
      "parameters": {
        "jsCode": "const diasSemana = {\n  \"Domingo\": 0, \"Lunes\": 1, \"Martes\": 2,\n  \"Miércoles\": 3, \"Miercoles\": 3,\n  \"Jueves\": 4, \"Viernes\": 5,\n  \"Sábado\": 6, \"Sabado\": 6\n};\n\nfunction proximaFecha(diaSemanaTexto) {\n  const hoy = new Date();\n  const diaObjetivo = diasSemana[diaSemanaTexto];\n  if (diaObjetivo === undefined) return null;\n  const diaActual = hoy.getDay();\n  let diff = diaObjetivo - diaActual;\n  if (diff < 0) diff += 7;\n  const resultado = new Date(hoy);\n  resultado.setDate(hoy.getDate() + diff);\n  const yyyy = resultado.getFullYear();\n  const mm = String(resultado.getMonth() + 1).padStart(2, '0');\n  const dd = String(resultado.getDate()).padStart(2, '0');\n  return `${yyyy}-${mm}-${dd}`;\n}\n\nconst opciones = [];\nconst vistos = new Set();\n\nfor (const item of items) {\n\n  const tutor = item.json;\n\n  const claveUnica = `${tutor.id_tutor}-${tutor.dia_semana}-${tutor.hora_inicio}`;\n\n  if (vistos.has(claveUnica)) {\n    continue;\n  }\n\n  vistos.add(claveUnica);\n\n  opciones.push({\n    opcion: opciones.length + 1,\n    id_tutor: tutor.id_tutor,\n    nombre_tutor: tutor.nombre,\n    fecha: proximaFecha(tutor.dia_semana),\n    dia_semana: tutor.dia_semana,\n    hora_inicio: tutor.hora_inicio,\n    hora_fin: tutor.hora_fin,\n    estado: tutor.estado\n  });\n}\n\nreturn opciones.slice(0,3).map(opcion => ({\n  json: opcion\n}));"
      },
