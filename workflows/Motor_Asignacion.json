      "parameters": {
        "jsCode": "const opciones = items.map(item => item.json);\n\nconst materia = $('Procesar mensaje usuario')\n.first()\n.json\n.materia_seleccionada;\n\nconst telefono = $('Procesar mensaje usuario')\n.first()\n.json\n.telefono;\n\nlet mensaje = \"👋 Hola.\\n\\n\";\nmensaje += `📚 Materia seleccionada: ${materia}\\n\\n`;\nmensaje += \"Encontré estas opciones disponibles para tu asesoría:\\n\\n\";\n\nfor (const opcion of opciones) {\n\n  mensaje += `👨‍🏫 ${opcion.opcion}. ${opcion.nombre_tutor}\\n`;\n  mensaje += `📅 ${opcion.fecha}\\n`;\n  mensaje += `⏰ ${opcion.hora_inicio} - ${opcion.hora_fin}\\n\\n`;\n\n}\n\nmensaje += \"✍️ Responde con el número de la opción que prefieras.\";\n\nreturn [\n{\n  json:{\n    mensaje,\n    telefono\n  }\n}\n];"
