      "parameters": {
        "jsCode": "const materia = $('Procesar mensaje usuario')\n.first()\n.json\n.materia_seleccionada;\n\nconst telefono = $('Procesar mensaje usuario')\n.first()\n.json\n.telefono || 'PRUEBA001';\n\nconst ahora = new Date().toISOString();\n\nreturn items.map(item => {\n\n  return {\n\n    json: {\n\n      id_chat: telefono,\n\n      telefono,\n\n      opcion: item.json.opcion,\n\n      id_tutor: item.json.id_tutor,\n\n      nombre_tutor: item.json.nombre_tutor,\n\n      materia: materia,\n\n      fecha: item.json.fecha,\n\n      dia_semana: item.json.dia_semana,\n\n      hora_inicio: item.json.hora_inicio,\n\n      hora_fin: item.json.hora_fin,\n\n      estado: \"Pendiente\",\n\n      fecha_creacion: ahora\n\n    }\n\n  };\n\n});"
