      "parameters": {
        "jsCode": "const mensaje = ($json.mensaje || \"\").toLowerCase().trim();\n\nlet respuesta = \"\";\nlet materiaSeleccionada = null;\n\n\nif (mensaje === \"hola\" || mensaje === \"inicio\") {\n\n  respuesta =\n`👋 Bienvenido a TutorBot 🤖\n\nSelecciona la materia para tu asesoría:\n\n1️⃣ JavaScript\n2️⃣ Python\n3️⃣ Java\n4️⃣ Bases de Datos\n5️⃣ HTML y CSS`;\n\n} \n\nelse if (mensaje === \"1\") {\n\n  materiaSeleccionada = \"JavaScript\";\n\n  respuesta = \n`Perfecto 👍\n\nSeleccionaste:\n💻 JavaScript\n\nBuscando tutores disponibles...`;\n\n}\n\nelse if (mensaje === \"2\") {\n\n  materiaSeleccionada = \"Python\";\n\n  respuesta = \n`Perfecto 👍\n\nSeleccionaste:\n🐍 Python\n\nBuscando tutores disponibles...`;\n\n}\n\nelse if (mensaje === \"3\") {\n\n  materiaSeleccionada = \"Java\";\n\n  respuesta = \n`Perfecto 👍\n\nSeleccionaste:\n☕ Java\n\nBuscando tutores disponibles...`;\n\n}\n\nelse if (mensaje === \"4\") {\n\n  materiaSeleccionada = \"Bases de Datos\";\n\n  respuesta =\n`Perfecto 👍\n\nSeleccionaste:\n🗄️ Bases de Datos\n\nBuscando tutores disponibles...`;\n\n}\n\nelse if (mensaje === \"5\") {\n\n  materiaSeleccionada = \"HTML y CSS\";\n\n  respuesta =\n`Perfecto 👍\n\nSeleccionaste:\n🌐 HTML y CSS\n\nBuscando tutores disponibles...`;\n\n}\n\nelse {\n\n  respuesta =\n`No entendí tu respuesta 😅\n\nPor favor escribe:\nHola\npara ver el menú de materias.`;\n\n}\n\n\nreturn [\n{\njson:{\nmensaje_usuario: mensaje,\nmateria_seleccionada: materiaSeleccionada,\nrespuesta,\ntelefono: $json.telefono || null\n}\n}\n];"
      },
